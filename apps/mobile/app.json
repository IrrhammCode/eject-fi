{
  "expo": {
    "name": "Eject.fi",
    "slug": "eject-fi",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0B0F"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "fi.eject.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0A0B0F"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "fi.eject.app"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "scheme": "ejectfi",
    "plugins": [
      "expo-secure-store",
      "expo-web-browser"
    ],
    "extra": {
      "eas": {
        "projectId": "48c0a1c8-061c-4aee-855c-35604cf2207a"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/48c0a1c8-061c-4aee-855c-35604cf2207a"
    }
  }
}
